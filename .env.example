# 禅道 MariaDB 连接信息。
ZENTAO_DB_HOST=10.70.33.18
ZENTAO_DB_PORT=3380
ZENTAO_DB_NAME=zentaoep
ZENTAO_DB_USER=bi_reader
ZENTAO_DB_PASSWORD=change-me

# bi_center 地址。服务会按不同数据流请求 {BI_CENTER_URL}/api/zentao/*/batch。
BI_CENTER_URL=https://neoflow.neo-net.com/bi_center
# Optional. Leave empty when bi_center only uses IP whitelist.
BI_CENTER_TOKEN=
# 管理接口鉴权。部署到服务器时建议务必配置一个长随机 token。
MANAGER_API_TOKEN=ZENTAO

# 首次补数起点和定时同步参数。
INITIAL_SYNC_START=2026-03-01 00:00:00
SYNC_INTERVAL_MINUTES=60
BATCH_SIZE=1000
# 每个数据流每轮最多发送几个批次。初次补数想快一些可临时调大，例如 10。
MAX_BATCHES_PER_STREAM=1
# 快照流每轮最多发送几个批次。任务/Bug/用例/文档等快照追数时可临时设为 20。
SNAPSHOT_MAX_BATCHES_PER_STREAM=1
# 可按需删减数据流；默认同步操作流水、AI评分、对象维度、用户部门、规则配置、用例和文档。
SYNC_STREAMS=actions,aiscore_results,tasks,bugs,stories,users,depts,aiscore_rules,ai_prompts,pivot_configs,cases,docs
FAILED_RETRY_INTERVAL_MINUTES=10
MAX_FAILED_RETRY_BATCHES=20
REQUEST_TIMEOUT_SECONDS=30

# SQLite 状态库路径，Docker Compose 中 /app/data 会挂载到宿主机 data 目录。
SQLITE_PATH=/app/data/zentao_manager.sqlite3
TZ=Asia/Shanghai
